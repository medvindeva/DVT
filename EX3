    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"fifa_world_cup_2026_player_performance.csv\")\n",
    "\n",
    "Q1 = df[\"market_value_eur\"].quantile(0.25)\n",
    "Q3 = df[\"market_value_eur\"].quantile(0.75)\n",
    "\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "lower = Q1 - 1.5 * IQR\n",
    "upper = Q3 + 1.5 * IQR\n",
    "\n",
    "outliers = df[(df[\"market_value_eur\"] < lower) | (df[\"market_value_eur\"] > upper)]\n",
    "\n",
    "print(outliers)\n"
   ]
